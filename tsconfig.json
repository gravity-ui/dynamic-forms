{
  "extends": "@gravity-ui/tsconfig/tsconfig.json",
  "include": ["src"],
  "compilerOptions": {
    "baseUrl": ".",
    "jsx": "react",
    "resolveJsonModule": true,
    "esModuleInterop": true,
    "paths": {
